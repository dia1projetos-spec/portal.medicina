/* main.css?v=2.0.0 */
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600&display=swap');

/* ============================================
   VARIABLES
   ============================================ */
:root {
  --purple:       #7B2FBE;
  --purple-deep:  #4A0E8F;
  --purple-dark:  #1A0530;
  --purple-mid:   #2D0B5A;
  --purple-glow:  rgba(123,47,190,0.35);
  --violet:       #9D4EDD;
  --lilac:        #C77DFF;
  --white:        #FFFFFF;
  --off-white:    #F5F0FF;
  --gray-light:   #E8E0F5;
  --gray-mid:     #9B8FB0;
  --text-dim:     #C4B8D9;

  --font-display: 'Syne', sans-serif;
  --font-body:    'Outfit', sans-serif;

  --nav-h: 76px;
  --r:     6px;
  --glow:  0 0 40px rgba(123,47,190,0.5);
  --shadow: 0 20px 60px rgba(10,3,20,0.5);
  --trans: 0.35s cubic-bezier(0.4,0,0.2,1);
}

/* ============================================
   RESET
   ============================================ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{
  font-family:var(--font-body);
  background:var(--purple-dark);
  color:var(--white);
  overflow-x:hidden;
  line-height:1.6;
  cursor:none;
}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}
ul{list-style:none}
button{cursor:none;border:none;background:none;font-family:inherit}

/* ============================================
   CUSTOM CURSOR (desktop only)
   ============================================ */
.cursor-dot,.cursor-ring{display:none}
@media(pointer:fine){
  .cursor-dot{
    display:block;
    position:fixed;
    width:8px;height:8px;
    background:var(--lilac);
    border-radius:50%;
    pointer-events:none;
    z-index:99999;
    transform:translate(-50%,-50%);
    transition:transform 0.1s;
  }
  .cursor-ring{
    display:block;
    position:fixed;
    width:36px;height:36px;
    border:1.5px solid rgba(157,78,221,0.6);
    border-radius:50%;
    pointer-events:none;
    z-index:99998;
    transform:translate(-50%,-50%);
    transition:transform 0.12s, width 0.2s, height 0.2s, border-color 0.2s;
  }
  .cursor-ring.hovering{
    width:56px;height:56px;
    border-color:var(--lilac);
    background:rgba(123,47,190,0.08);
  }
  body{cursor:none}
  button{cursor:none}
}
@media(pointer:coarse){
  body{cursor:auto}
  button{cursor:pointer}
}

/* ============================================
   LOADER / SPLASH SCREEN
   ============================================ */
#loader{
  position:fixed;inset:0;
  background:var(--purple-dark);
  z-index:9999;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  transition:opacity 0.8s ease, visibility 0.8s ease;
}
#loader.hide{opacity:0;visibility:hidden;pointer-events:none}

.loader-skull{
  position:relative;
  margin-bottom:32px;
  animation:skullFloat 3s ease-in-out infinite;
}
@keyframes skullFloat{
  0%,100%{transform:translateY(0) rotate(-3deg)}
  50%{transform:translateY(-18px) rotate(3deg)}
}

.loader-skull svg{
  width:120px;height:120px;
  filter:drop-shadow(0 0 24px var(--purple)) drop-shadow(0 0 60px rgba(123,47,190,0.4));
  animation:skullGlow 2s ease-in-out infinite alternate;
}
@media(max-width:480px){
  .loader-skull svg{width:90px;height:90px}
}
@keyframes skullGlow{
  from{filter:drop-shadow(0 0 20px var(--purple)) drop-shadow(0 0 50px rgba(123,47,190,0.3))}
  to{filter:drop-shadow(0 0 40px var(--lilac)) drop-shadow(0 0 80px rgba(199,125,255,0.5))}
}

.loader-rings{
  position:absolute;
  top:50%;left:50%;
  transform:translate(-50%,-50%);
  pointer-events:none;
}
.loader-ring{
  position:absolute;
  border-radius:50%;
  border:1px solid rgba(123,47,190,0.3);
  top:50%;left:50%;
  transform:translate(-50%,-50%);
  animation:ringExpand 3s linear infinite;
}
.loader-ring:nth-child(1){width:180px;height:180px;animation-delay:0s}
.loader-ring:nth-child(2){width:240px;height:240px;animation-delay:0.8s}
.loader-ring:nth-child(3){width:300px;height:300px;animation-delay:1.6s}
@keyframes ringExpand{
  0%{opacity:0.6;transform:translate(-50%,-50%) scale(0.8)}
  100%{opacity:0;transform:translate(-50%,-50%) scale(1.3)}
}

.loader-title{
  font-family:var(--font-display);
  font-size:clamp(1.8rem,6vw,2.8rem);
  font-weight:800;
  letter-spacing:10px;
  text-transform:uppercase;
  background:linear-gradient(135deg,var(--white) 0%,var(--lilac) 50%,var(--white) 100%);
  background-size:200% 100%;
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  animation:shimmer 2.5s linear infinite;
  margin-bottom:8px;
}
@keyframes shimmer{
  0%{background-position:200% 0}
  100%{background-position:-200% 0}
}

.loader-subtitle{
  font-family:var(--font-body);
  font-size:11px;
  letter-spacing:5px;
  text-transform:uppercase;
  color:var(--gray-mid);
  margin-bottom:48px;
}

.loader-bar-wrap{
  width:min(280px,80vw);
  height:2px;
  background:rgba(255,255,255,0.08);
  border-radius:2px;
  overflow:hidden;
  position:relative;
  margin-bottom:16px;
}
.loader-bar{
  height:100%;
  width:0%;
  background:linear-gradient(90deg,var(--purple),var(--lilac),var(--purple));
  background-size:200% 100%;
  border-radius:2px;
  animation:barGlow 1.5s ease-in-out infinite alternate, loadProgress 2.8s cubic-bezier(0.4,0,0.2,1) forwards;
}
@keyframes barGlow{
  from{box-shadow:0 0 8px var(--purple)}
  to{box-shadow:0 0 20px var(--lilac)}
}
@keyframes loadProgress{
  0%{width:0%}
  30%{width:35%}
  60%{width:65%}
  85%{width:88%}
  100%{width:100%}
}
.loader-pct{
  font-family:var(--font-display);
  font-size:12px;
  letter-spacing:2px;
  color:var(--lilac);
}

/* Particles */
.loader-particles{
  position:absolute;
  inset:0;
  pointer-events:none;
  overflow:hidden;
}
.lp{
  position:absolute;
  width:2px;height:2px;
  border-radius:50%;
  background:var(--lilac);
  opacity:0;
  animation:particleFloat var(--dur) var(--delay) linear infinite;
}
@keyframes particleFloat{
  0%{opacity:0;transform:translateY(100vh) translateX(var(--tx))}
  10%{opacity:0.8}
  90%{opacity:0.4}
  100%{opacity:0;transform:translateY(-10vh) translateX(var(--tx))}
}

/* ============================================
   NAVIGATION
   ============================================ */
.nav{
  position:fixed;top:0;left:0;right:0;
  height:var(--nav-h);
  z-index:1000;
  display:flex;align-items:center;
  transition:var(--trans);
}
.nav.solid{
  background:rgba(26,5,48,0.95);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(123,47,190,0.2);
  box-shadow:0 4px 30px rgba(0,0,0,0.4);
}
.nav-inner{
  display:flex;align-items:center;justify-content:space-between;width:100%;
  max-width:1300px;margin:0 auto;padding:0 24px;
}
.nav-logo{
  display:flex;align-items:center;gap:12px;
  flex-shrink:0;
}
.logo-icon{
  width:44px;height:44px;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 20px var(--purple-glow);
  border:1px solid rgba(123,47,190,0.4);
}
.logo-icon svg{width:22px;height:22px;fill:var(--white)}
.logo-text strong{
  display:block;
  font-family:var(--font-display);
  font-size:20px;
  font-weight:800;
  letter-spacing:1px;
  background:linear-gradient(135deg,var(--white),var(--lilac));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.logo-text span{
  font-size:9px;letter-spacing:3.5px;text-transform:uppercase;
  color:var(--gray-mid);font-weight:400;
}
.nav-links{
  display:flex;align-items:center;gap:32px;
}
.nav-links a{
  font-family:var(--font-display);
  font-size:13px;font-weight:600;
  letter-spacing:1px;text-transform:uppercase;
  color:rgba(255,255,255,0.65);
  position:relative;transition:color 0.25s;
  white-space:nowrap;
}
.nav-links a::after{
  content:'';
  position:absolute;bottom:-4px;left:0;
  width:0;height:1.5px;
  background:linear-gradient(90deg,var(--purple),var(--lilac));
  transition:width 0.3s;
}
.nav-links a:hover{color:var(--white)}
.nav-links a:hover::after,.nav-links a.active::after{width:100%}
.nav-links a.active{color:var(--lilac)}

.nav-actions{display:flex;align-items:center;gap:10px}
.btn-nav-ghost{
  font-family:var(--font-display);font-size:12px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  color:rgba(255,255,255,0.7);
  padding:9px 16px;border:1px solid rgba(255,255,255,0.15);
  border-radius:var(--r);transition:var(--trans);
  display:flex;align-items:center;gap:8px;
  white-space:nowrap;
}
.btn-nav-ghost:hover{border-color:var(--violet);color:var(--white);background:rgba(123,47,190,0.15)}
.btn-nav-ghost svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}
.btn-nav-solid{
  font-family:var(--font-display);font-size:12px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  color:var(--white);padding:10px 20px;border-radius:var(--r);
  transition:var(--trans);border:1px solid rgba(123,47,190,0.5);
  box-shadow:0 0 20px rgba(123,47,190,0.3);
  white-space:nowrap;
}
.btn-nav-solid:hover{
  transform:translateY(-2px);
  box-shadow:0 0 30px rgba(123,47,190,0.6),0 8px 24px rgba(0,0,0,0.3);
}

/* Hamburger */
.nav-hamburger{
  display:none;
  flex-direction:column;gap:5px;
  padding:8px;cursor:pointer;
  background:none;border:none;
}
.nav-hamburger span{
  display:block;width:24px;height:2px;
  background:var(--white);border-radius:2px;
  transition:var(--trans);
}
.nav-hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.nav-hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* Mobile nav drawer */
.nav-mobile{
  display:none;
  position:fixed;top:var(--nav-h);left:0;right:0;
  background:rgba(26,5,48,0.98);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(123,47,190,0.2);
  z-index:999;
  padding:20px 24px 32px;
  flex-direction:column;gap:0;
  transform:translateY(-100%);
  opacity:0;
  transition:transform 0.3s ease,opacity 0.3s ease;
  pointer-events:none;
}
.nav-mobile.open{
  transform:translateY(0);
  opacity:1;
  pointer-events:all;
}
.nav-mobile a{
  display:block;
  font-family:var(--font-display);font-size:15px;font-weight:700;
  letter-spacing:1px;text-transform:uppercase;
  color:rgba(255,255,255,0.7);
  padding:14px 0;
  border-bottom:1px solid rgba(123,47,190,0.12);
  transition:color 0.2s;
}
.nav-mobile a:last-of-type{border-bottom:none}
.nav-mobile a:hover{color:var(--lilac)}
.nav-mobile-btns{
  display:flex;flex-direction:column;gap:10px;
  margin-top:20px;
}
.nav-mobile-btns .btn-nav-ghost,.nav-mobile-btns .btn-nav-solid{
  text-align:center;justify-content:center;
}

/* ============================================
   HERO
   ============================================ */
.hero{
  min-height:100vh;
  position:relative;
  display:grid;
  grid-template-columns:1fr 1fr;
  align-items:center;
  overflow:hidden;
  padding-top:var(--nav-h);
}

/* Video BG */
.hero-video-bg{
  position:absolute;inset:0;
  z-index:0;overflow:hidden;
}
.hero-video-bg video{
  width:100%;height:100%;
  object-fit:cover;
  opacity:0.12;
}
.hero-video-bg::after{
  content:'';
  position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(26,5,48,0.97) 40%,rgba(74,14,143,0.6) 100%);
}

/* Grid noise texture */
.hero::before{
  content:'';
  position:absolute;inset:0;
  background-image:
    radial-gradient(circle at 20% 50%, rgba(123,47,190,0.15) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(157,78,221,0.1) 0%, transparent 40%);
  z-index:1;pointer-events:none;
}

.hero-left{
  position:relative;z-index:2;
  padding:80px 40px 80px 60px;
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  background:rgba(123,47,190,0.15);
  border:1px solid rgba(123,47,190,0.35);
  border-radius:50px;
  padding:8px 16px;
  margin-bottom:28px;
}
.hero-eyebrow-dot{
  width:7px;height:7px;border-radius:50%;
  background:var(--lilac);
  animation:blink 1.8s ease-in-out infinite;
  flex-shrink:0;
}
@keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}
.hero-eyebrow span{
  font-family:var(--font-display);font-size:10px;
  font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--lilac);
}

.hero-h1{
  font-family:var(--font-display);
  font-size:clamp(2.6rem,4.5vw,5rem);
  font-weight:800;line-height:1.05;
  margin-bottom:24px;
}
.hero-h1 .line-normal{color:var(--white);display:block}
.hero-h1 .line-accent{
  display:block;
  background:linear-gradient(135deg,var(--lilac) 0%,var(--white) 60%,var(--lilac) 100%);
  background-size:200%;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:shimmer 4s linear infinite;
}
.hero-h1 .line-outlined{
  display:block;
  -webkit-text-stroke:1.5px var(--purple);
  color:transparent;
}

.hero-desc{
  font-size:15px;color:var(--text-dim);
  line-height:1.75;max-width:480px;margin-bottom:40px;
}
.hero-desc strong{color:var(--lilac);font-weight:600}

.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:52px}

.btn-primary{
  display:inline-flex;align-items:center;gap:10px;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  color:var(--white);
  font-family:var(--font-display);font-size:13px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  padding:14px 28px;border-radius:var(--r);
  border:1px solid rgba(123,47,190,0.5);
  box-shadow:0 0 30px rgba(123,47,190,0.4);
  transition:var(--trans);
}
.btn-primary svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}
.btn-primary:hover{
  transform:translateY(-3px);
  box-shadow:0 0 50px rgba(123,47,190,0.7),0 12px 30px rgba(0,0,0,0.4);
}
.btn-ghost{
  display:inline-flex;align-items:center;gap:10px;
  color:rgba(255,255,255,0.7);
  font-family:var(--font-display);font-size:13px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  padding:13px 26px;border-radius:var(--r);
  border:1px solid rgba(255,255,255,0.15);
  transition:var(--trans);
}
.btn-ghost:hover{border-color:var(--violet);color:var(--white);background:rgba(123,47,190,0.12)}

.hero-stats{
  display:flex;gap:28px;flex-wrap:wrap;
}
.hero-stat-num{
  font-family:var(--font-display);
  font-size:1.8rem;font-weight:800;
  color:var(--lilac);display:block;line-height:1;
}
.hero-stat-label{
  font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
  color:var(--gray-mid);margin-top:4px;display:block;
}
.hero-stat-sep{
  width:1px;background:rgba(255,255,255,0.08);
  align-self:stretch;
}

/* RIGHT SIDE — Doctor Skull Image */
.hero-right{
  position:relative;z-index:2;
  height:100%;min-height:100vh;
  display:flex;align-items:center;justify-content:center;
}
.hero-img-frame{
  position:relative;
  width:100%;height:100%;
  display:flex;align-items:center;justify-content:flex-end;
}
.hero-img-main{
  width:100%;
  height:100vh;
  object-fit:cover;
  object-position:center top;
  position:relative;z-index:2;
  mask-image:linear-gradient(to right,transparent 0%,black 25%,black 85%,transparent 100%),
             linear-gradient(to bottom,transparent 0%,black 10%,black 90%,transparent 100%);
  mask-composite:intersect;
  -webkit-mask-image:linear-gradient(to right,transparent 0%,black 25%,black 85%,transparent 100%),
                     linear-gradient(to bottom,transparent 0%,black 10%,black 90%,transparent 100%);
  -webkit-mask-composite:source-in;
}
.hero-img-glow{
  position:absolute;
  bottom:-60px;left:50%;
  transform:translateX(-50%);
  width:400px;height:300px;
  background:radial-gradient(ellipse,rgba(123,47,190,0.5) 0%,transparent 70%);
  z-index:1;filter:blur(40px);
  animation:glowPulse 3s ease-in-out infinite alternate;
}
@keyframes glowPulse{
  from{opacity:0.6;transform:translateX(-50%) scale(0.9)}
  to{opacity:1;transform:translateX(-50%) scale(1.1)}
}
.hero-img-accent{
  position:absolute;top:40px;right:40px;z-index:3;
  background:rgba(26,5,48,0.85);
  backdrop-filter:blur(12px);
  border:1px solid rgba(123,47,190,0.4);
  border-radius:12px;
  padding:16px 20px;
  box-shadow:var(--glow);
}
.hero-img-accent strong{
  font-family:var(--font-display);font-size:1.6rem;font-weight:800;
  color:var(--lilac);display:block;line-height:1;
}
.hero-img-accent span{
  font-size:10px;letter-spacing:2px;text-transform:uppercase;
  color:var(--gray-mid);
}
.hero-badge-float{
  position:absolute;bottom:120px;left:20px;z-index:3;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  border:1px solid rgba(123,47,190,0.5);
  border-radius:50px;
  padding:10px 20px;
  box-shadow:var(--glow);
  display:flex;align-items:center;gap:10px;
  animation:badgeFloat 4s ease-in-out infinite;
}
@keyframes badgeFloat{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-10px)}
}
.hero-badge-float svg{width:18px;height:18px;fill:var(--lilac);flex-shrink:0}
.hero-badge-float span{
  font-family:var(--font-display);font-size:11px;font-weight:700;
  letter-spacing:1px;color:var(--white);
}

/* ============================================
   MARQUEE
   ============================================ */
.marquee-wrap{
  padding:18px 0;
  border-top:1px solid rgba(123,47,190,0.2);
  border-bottom:1px solid rgba(123,47,190,0.2);
  background:rgba(123,47,190,0.06);
  overflow:hidden;
  position:relative;z-index:2;
}
.marquee-track{
  display:flex;gap:0;width:max-content;
  animation:marquee 30s linear infinite;
}
.marquee-item{
  font-family:var(--font-display);
  font-size:12px;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;
  color:rgba(255,255,255,0.4);
  padding:0 32px;
  white-space:nowrap;
  display:flex;align-items:center;gap:32px;
}
.marquee-item::after{
  content:'✦';
  font-size:8px;
  color:var(--purple);
  margin-left:0;
}
@keyframes marquee{
  from{transform:translateX(0)}
  to{transform:translateX(-50%)}
}

/* ============================================
   SECTION COMMONS
   ============================================ */
.section-label{
  font-family:var(--font-display);
  font-size:11px;font-weight:700;
  letter-spacing:4px;text-transform:uppercase;
  color:var(--lilac);
  display:flex;align-items:center;gap:14px;
  margin-bottom:20px;
}
.section-label::before{
  content:'';width:28px;height:1.5px;
  background:linear-gradient(90deg,var(--purple),var(--lilac));
  flex-shrink:0;
}
.section-title{
  font-family:var(--font-display);
  font-size:clamp(1.8rem,3.5vw,3.2rem);
  font-weight:800;line-height:1.1;
  color:var(--white);
}
.section-title em{
  font-style:italic;font-weight:800;
  background:linear-gradient(135deg,var(--lilac),var(--white));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.section-desc{
  font-size:15px;color:var(--text-dim);
  line-height:1.75;max-width:520px;
}

/* ============================================
   FEATURES
   ============================================ */
.features{
  padding:100px 0;
  position:relative;
}
.features-container{
  max-width:1300px;margin:0 auto;padding:0 24px;
}
.features-header{
  display:grid;grid-template-columns:1fr 1fr;
  gap:40px;align-items:end;margin-bottom:60px;
}
.features-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:2px;
}
.feat-card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(123,47,190,0.15);
  padding:36px 24px;
  position:relative;overflow:hidden;
  transition:var(--trans);
}
.feat-card::before{
  content:'';
  position:absolute;top:0;left:0;
  width:100%;height:2px;
  background:linear-gradient(90deg,var(--purple),var(--lilac));
  transform:scaleX(0);transform-origin:left;
  transition:transform 0.4s;
}
.feat-card::after{
  content:'';
  position:absolute;inset:0;
  background:radial-gradient(circle at 50% 0%,rgba(123,47,190,0.08) 0%,transparent 70%);
  opacity:0;transition:opacity 0.4s;
}
.feat-card:hover{
  border-color:rgba(123,47,190,0.4);
  transform:translateY(-6px);
  box-shadow:0 20px 60px rgba(0,0,0,0.4),0 0 30px rgba(123,47,190,0.2);
}
.feat-card:hover::before{transform:scaleX(1)}
.feat-card:hover::after{opacity:1}
.feat-num{
  font-family:var(--font-display);
  font-size:4.5rem;font-weight:800;
  color:rgba(123,47,190,0.12);
  line-height:1;margin-bottom:16px;
  transition:color 0.3s;
}
.feat-card:hover .feat-num{color:rgba(123,47,190,0.25)}
.feat-icon{
  width:50px;height:50px;
  background:linear-gradient(135deg,rgba(123,47,190,0.3),rgba(74,14,143,0.3));
  border:1px solid rgba(123,47,190,0.3);
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:20px;
}
.feat-icon svg{width:22px;height:22px;stroke:var(--lilac);fill:none;stroke-width:1.8}
.feat-card h3{
  font-family:var(--font-display);
  font-size:1.1rem;font-weight:700;
  color:var(--white);margin-bottom:12px;
}
.feat-card p{font-size:13px;color:var(--text-dim);line-height:1.65}

/* ============================================
   ABOUT / HIGHLIGHT SECTION
   ============================================ */
.about{
  padding:100px 0;
  position:relative;overflow:hidden;
}
.about::before{
  content:'';
  position:absolute;
  left:-200px;top:50%;transform:translateY(-50%);
  width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(123,47,190,0.12) 0%,transparent 70%);
  pointer-events:none;
}
.about-container{
  max-width:1300px;margin:0 auto;padding:0 24px;
}
.about-inner{
  display:grid;grid-template-columns:1fr 1fr;
  gap:60px;align-items:center;
}

/* Image side */
.about-visual{
  position:relative;
}
.about-img-wrap{
  position:relative;
  border-radius:20px;overflow:hidden;
}
.about-img-wrap::before{
  content:'';
  position:absolute;inset:0;
  background:linear-gradient(180deg,transparent 40%,rgba(26,5,48,0.8) 100%);
  z-index:1;
}
.about-img-main-img{
  width:100%;
  height:520px;
  object-fit:cover;
  object-position:center top;
  display:block;
  transition:transform 0.8s ease;
}
.about-img-wrap:hover .about-img-main-img{transform:scale(1.04)}

.about-img-border{
  position:absolute;inset:-2px;
  border-radius:22px;
  background:linear-gradient(135deg,var(--purple),transparent,var(--violet));
  z-index:-1;
}
.about-tag{
  position:absolute;bottom:24px;left:24px;z-index:2;
  background:rgba(26,5,48,0.9);
  backdrop-filter:blur(12px);
  border:1px solid rgba(123,47,190,0.4);
  border-radius:12px;
  padding:14px 20px;
}
.about-tag strong{
  font-family:var(--font-display);font-size:1.4rem;font-weight:800;
  color:var(--lilac);display:block;line-height:1;
}
.about-tag span{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-mid)}

/* Floating decoration */
.about-deco{
  position:absolute;top:-20px;right:-20px;
  width:90px;height:90px;
  border:1px solid rgba(123,47,190,0.3);
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  background:rgba(26,5,48,0.8);
  backdrop-filter:blur(8px);
  animation:rotateSlow 20s linear infinite;
}
.about-deco svg{width:46px;height:46px;fill:rgba(123,47,190,0.6)}
@keyframes rotateSlow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

/* Text side */
.about-text .section-title{margin-bottom:24px}
.about-text p{
  font-size:15px;color:var(--text-dim);
  line-height:1.8;margin-bottom:20px;
}
.about-text p strong{color:var(--white);font-weight:600}
.about-list{
  margin:28px 0;display:flex;flex-direction:column;gap:12px;
}
.about-list li{
  display:flex;align-items:flex-start;gap:14px;
  font-size:14px;color:rgba(255,255,255,0.75);
}
.about-check{
  width:22px;height:22px;min-width:22px;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  margin-top:1px;
  box-shadow:0 0 12px rgba(123,47,190,0.4);
}
.about-check svg{width:11px;height:11px;stroke:var(--white);fill:none;stroke-width:3}

/* ============================================
   VIDEO SECTION
   ============================================ */
.video-section{
  padding:100px 0;
  position:relative;overflow:hidden;
  background:rgba(255,255,255,0.015);
  border-top:1px solid rgba(123,47,190,0.12);
  border-bottom:1px solid rgba(123,47,190,0.12);
}
.video-container{
  max-width:1300px;margin:0 auto;padding:0 24px;
}
.video-inner{
  display:grid;grid-template-columns:1fr 1.4fr;
  gap:60px;align-items:center;
}
.video-text .section-title{margin-bottom:20px}
.video-text p{
  font-size:15px;color:var(--text-dim);
  line-height:1.75;margin-bottom:32px;
}
.video-wrap{
  position:relative;
  border-radius:20px;overflow:hidden;
  box-shadow:0 0 80px rgba(123,47,190,0.3),var(--shadow);
  border:1px solid rgba(123,47,190,0.3);
}
.video-wrap video{
  width:100%;display:block;
}
.video-wrap::before{
  content:'';
  position:absolute;inset:0;
  border-radius:20px;
  background:linear-gradient(180deg,transparent 60%,rgba(26,5,48,0.6) 100%);
  z-index:1;pointer-events:none;
}
.video-label{
  position:absolute;bottom:20px;left:20px;z-index:2;
  font-family:var(--font-display);font-size:11px;
  font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--lilac);
  display:flex;align-items:center;gap:8px;
}
.video-live-dot{
  width:8px;height:8px;border-radius:50%;
  background:#ff4444;
  animation:blink 1.5s ease-in-out infinite;
}

/* ============================================
   COURSES
   ============================================ */
.courses{
  padding:100px 0;
}
.courses-container{
  max-width:1300px;margin:0 auto;padding:0 24px;
}
.courses-header{
  display:flex;justify-content:space-between;align-items:flex-end;
  margin-bottom:52px;flex-wrap:wrap;gap:16px;
}
.courses-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:20px;
}
.course-card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(123,47,190,0.15);
  border-radius:16px;overflow:hidden;
  transition:var(--trans);
  position:relative;
}
.course-card:hover{
  border-color:rgba(123,47,190,0.45);
  transform:translateY(-8px);
  box-shadow:0 30px 80px rgba(0,0,0,0.5),0 0 40px rgba(123,47,190,0.2);
}
.course-img{
  height:200px;overflow:hidden;position:relative;
}
.course-img img{
  width:100%;height:100%;object-fit:cover;
  transition:transform 0.7s;
}
.course-card:hover .course-img img{transform:scale(1.1)}
.course-img-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(26,5,48,1) 0%,transparent 60%);
}
.course-badge{
  position:absolute;top:14px;right:14px;
  background:rgba(123,47,190,0.9);
  backdrop-filter:blur(8px);
  color:var(--white);font-family:var(--font-display);
  font-size:10px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;padding:5px 12px;border-radius:50px;
  border:1px solid rgba(255,255,255,0.15);
}
.course-body{padding:24px}
.course-body h3{
  font-family:var(--font-display);font-size:1.15rem;
  font-weight:700;color:var(--white);margin-bottom:10px;
}
.course-body p{font-size:13px;color:var(--text-dim);line-height:1.6;margin-bottom:20px}
.course-meta{
  display:flex;gap:12px;flex-wrap:wrap;
  border-top:1px solid rgba(255,255,255,0.06);
  padding-top:16px;
}
.course-meta-item{
  display:flex;align-items:center;gap:6px;
  font-size:11px;color:var(--gray-mid);
}
.course-meta-item svg{width:12px;height:12px;stroke:var(--lilac);fill:none;stroke-width:2}

/* ============================================
   BLOG
   ============================================ */
.blog{
  padding:100px 0;
  background:rgba(255,255,255,0.015);
}
.blog-container{
  max-width:1300px;margin:0 auto;padding:0 24px;
}
.blog-header{
  display:flex;justify-content:space-between;align-items:flex-end;
  margin-bottom:52px;flex-wrap:wrap;gap:16px;
}
.blog-grid{
  display:grid;
  grid-template-columns:1.7fr 1fr;
  grid-template-rows:auto auto;
  gap:20px;
}
.blog-card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(123,47,190,0.15);
  border-radius:16px;overflow:hidden;
  transition:var(--trans);
}
.blog-card:hover{
  border-color:rgba(123,47,190,0.4);
  transform:translateY(-4px);
  box-shadow:0 20px 60px rgba(0,0,0,0.4),0 0 30px rgba(123,47,190,0.15);
}
.blog-card.featured{grid-row:span 2;display:flex;flex-direction:column}
.blog-card-img{overflow:hidden;position:relative}
.blog-card.featured .blog-card-img{height:300px}
.blog-card:not(.featured) .blog-card-img{height:140px}
.blog-card-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s}
.blog-card:hover .blog-card-img img{transform:scale(1.07)}
.blog-card-img-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(26,5,48,0.9) 0%,transparent 60%);
}
.blog-card-body{
  padding:24px;flex:1;display:flex;flex-direction:column;
}
.blog-card:not(.featured) .blog-card-body{padding:16px}
.blog-cat{
  font-family:var(--font-display);font-size:10px;
  font-weight:700;letter-spacing:2.5px;text-transform:uppercase;
  color:var(--lilac);margin-bottom:10px;display:block;
}
.blog-card h3{
  font-family:var(--font-display);
  color:var(--white);line-height:1.25;
  margin-bottom:12px;flex:1;
  transition:color 0.25s;
}
.blog-card.featured h3{font-size:1.4rem;font-weight:700}
.blog-card:not(.featured) h3{font-size:0.95rem;font-weight:700}
.blog-card:hover h3{color:var(--lilac)}
.blog-card p{
  font-size:13px;color:var(--text-dim);
  line-height:1.65;margin-bottom:20px;
}
.blog-card:not(.featured) p{display:none}
.blog-meta{
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid rgba(255,255,255,0.06);
  padding-top:14px;margin-top:auto;
}
.blog-date{font-size:11px;color:var(--gray-mid);letter-spacing:0.5px}
.blog-read{
  font-family:var(--font-display);font-size:11px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  color:var(--lilac);display:flex;align-items:center;gap:6px;
  transition:gap 0.25s;
}
.blog-read svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2}
.blog-card:hover .blog-read{gap:12px}

/* ============================================
   TESTIMONIALS
   ============================================ */
.testimonials{
  padding:100px 0;
}
.test-container{
  max-width:1300px;margin:0 auto;padding:0 24px;
}
.test-inner{
  display:grid;grid-template-columns:1fr 2fr;gap:60px;align-items:center;
}
.test-left .section-title{margin-bottom:20px}
.test-left p{font-size:15px;color:var(--text-dim);line-height:1.7;margin-bottom:32px}
.test-btns{display:flex;gap:10px}
.test-btn{
  width:46px;height:46px;border-radius:50%;
  border:1px solid rgba(123,47,190,0.3);
  display:flex;align-items:center;justify-content:center;
  color:var(--gray-mid);transition:var(--trans);
}
.test-btn svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2}
.test-btn:hover,.test-btn.active{
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  border-color:var(--purple);color:var(--white);
  box-shadow:0 0 20px rgba(123,47,190,0.4);
}
.test-slider{overflow:hidden}
.test-track{display:flex;transition:transform 0.6s cubic-bezier(0.4,0,0.2,1)}
.test-card{
  min-width:100%;
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(123,47,190,0.2);
  border-radius:20px;
  padding:40px;
  position:relative;overflow:hidden;
}
.test-card::before{
  content:'\201C';
  font-family:var(--font-display);
  font-size:9rem;font-weight:800;
  color:rgba(123,47,190,0.08);
  position:absolute;top:0;left:24px;line-height:1;
  pointer-events:none;
}
.test-stars{color:var(--lilac);font-size:15px;letter-spacing:3px;margin-bottom:20px}
.test-text{
  font-family:'Outfit',sans-serif;
  font-size:1.1rem;font-style:italic;
  color:rgba(255,255,255,0.85);
  line-height:1.7;margin-bottom:28px;
  position:relative;
}
.test-author{display:flex;align-items:center;gap:16px}
.test-avatar{
  width:48px;height:48px;border-radius:50%;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-display);font-size:1rem;font-weight:800;
  color:var(--white);
  border:2px solid rgba(123,47,190,0.5);
  box-shadow:0 0 16px rgba(123,47,190,0.4);
  flex-shrink:0;
}
.test-name{
  font-family:var(--font-display);font-size:1rem;font-weight:700;
  color:var(--white);display:block;
}
.test-role{font-size:12px;color:var(--gray-mid)}

/* ============================================
   CTA
   ============================================ */
.cta{
  padding:100px 0;
  position:relative;overflow:hidden;
  background:linear-gradient(135deg,rgba(123,47,190,0.08) 0%,rgba(74,14,143,0.12) 100%);
  border-top:1px solid rgba(123,47,190,0.15);
}
.cta::before{
  content:'';
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  width:min(800px,100vw);height:min(800px,100vw);border-radius:50%;
  background:radial-gradient(circle,rgba(123,47,190,0.12) 0%,transparent 70%);
  pointer-events:none;
}
.cta-container{
  max-width:1300px;margin:0 auto;padding:0 24px;
  text-align:center;position:relative;z-index:1;
}
.cta .section-label{justify-content:center}
.cta .section-title{margin-bottom:20px}
.cta p{
  font-size:16px;color:var(--text-dim);
  max-width:560px;margin:0 auto 40px;line-height:1.75;
}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* ============================================
   FOOTER
   ============================================ */
.footer{
  background:#0D0220;
  padding:72px 0 0;
  border-top:1px solid rgba(123,47,190,0.15);
}
.footer-container{max-width:1300px;margin:0 auto;padding:0 24px}
.footer-grid{
  display:grid;grid-template-columns:2fr 1fr 1fr 1.5fr;
  gap:48px;padding-bottom:52px;
  border-bottom:1px solid rgba(255,255,255,0.05);
}
.footer-brand p{
  font-size:13px;color:var(--gray-mid);
  line-height:1.7;max-width:260px;margin:18px 0 24px;
}
.footer-social{display:flex;gap:10px;flex-wrap:wrap}
.footer-social a{
  width:38px;height:38px;
  border:1px solid rgba(123,47,190,0.25);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;color:var(--gray-mid);
  transition:var(--trans);
}
.footer-social a:hover{
  border-color:var(--purple);color:var(--lilac);
  background:rgba(123,47,190,0.15);
  box-shadow:0 0 12px rgba(123,47,190,0.3);
}
.footer-col h4{
  font-family:var(--font-display);font-size:11px;
  font-weight:700;letter-spacing:3px;text-transform:uppercase;
  color:var(--white);margin-bottom:18px;
}
.footer-col ul{display:flex;flex-direction:column;gap:12px}
.footer-col ul li a{
  font-size:13px;color:var(--gray-mid);transition:color 0.25s;
}
.footer-col ul li a:hover{color:var(--lilac)}
.newsletter-input-wrap{display:flex;gap:0}
.newsletter-input-wrap input{
  flex:1;background:rgba(255,255,255,0.04);
  border:1px solid rgba(123,47,190,0.25);
  border-right:none;padding:11px 14px;
  font-family:var(--font-body);font-size:13px;
  color:var(--white);border-radius:var(--r) 0 0 var(--r);outline:none;
  transition:border-color 0.25s;min-width:0;
}
.newsletter-input-wrap input:focus{border-color:rgba(123,47,190,0.6)}
.newsletter-input-wrap input::placeholder{color:rgba(255,255,255,0.25)}
.newsletter-input-wrap button{
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  color:var(--white);font-weight:700;font-size:13px;
  padding:11px 16px;border-radius:0 var(--r) var(--r) 0;
  border:1px solid rgba(123,47,190,0.4);
  transition:var(--trans);flex-shrink:0;
}
.newsletter-input-wrap button:hover{
  box-shadow:0 0 20px rgba(123,47,190,0.5);
}
.footer-bottom{
  padding:24px 0;
  display:flex;justify-content:space-between;align-items:center;
  font-size:12px;color:rgba(255,255,255,0.25);
  flex-wrap:wrap;gap:12px;
}
.footer-bottom-links{display:flex;gap:20px;flex-wrap:wrap}
.footer-bottom-links a{color:rgba(255,255,255,0.25);transition:color 0.25s}
.footer-bottom-links a:hover{color:var(--lilac)}

/* ============================================
   LOGIN MODAL
   ============================================ */
.modal-overlay{
  position:fixed;inset:0;
  background:rgba(10,3,20,0.92);
  backdrop-filter:blur(12px);
  z-index:2000;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity 0.35s;
  padding:16px;
}
.modal-overlay.active{opacity:1;pointer-events:all}
.modal{
  background:var(--purple-mid);
  border:1px solid rgba(123,47,190,0.35);
  border-radius:20px;
  width:100%;max-width:460px;
  overflow:hidden;
  overflow-y:auto;
  max-height:90vh;
  transform:translateY(24px) scale(0.97);
  transition:transform 0.35s cubic-bezier(0.4,0,0.2,1);
  box-shadow:0 0 80px rgba(123,47,190,0.3),var(--shadow);
}
.modal-overlay.active .modal{transform:translateY(0) scale(1)}
.modal-header{
  background:linear-gradient(135deg,rgba(123,47,190,0.2),rgba(74,14,143,0.3));
  padding:32px 32px 24px;
  border-bottom:1px solid rgba(123,47,190,0.2);
  position:relative;
}
.modal-header h2{
  font-family:var(--font-display);font-size:1.6rem;font-weight:800;
  color:var(--white);margin-bottom:6px;
}
.modal-header p{font-size:13px;color:var(--gray-mid)}
.modal-close{
  position:absolute;top:18px;right:18px;
  width:36px;height:36px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  color:var(--gray-mid);transition:var(--trans);
}
.modal-close:hover{background:rgba(255,255,255,0.08);color:var(--white)}
.modal-close svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2}
.modal-tabs{
  display:flex;border-bottom:1px solid rgba(255,255,255,0.06);
}
.modal-tab{
  flex:1;padding:16px;text-align:center;
  font-family:var(--font-display);font-size:12px;font-weight:700;
  letter-spacing:1px;text-transform:uppercase;
  color:var(--gray-mid);transition:var(--trans);
  cursor:pointer;position:relative;
}
.modal-tab::after{
  content:'';position:absolute;bottom:-1px;left:0;
  width:100%;height:2px;
  background:linear-gradient(90deg,var(--purple),var(--lilac));
  transform:scaleX(0);transition:transform 0.3s;
}
.modal-tab.active{color:var(--white)}
.modal-tab.active::after{transform:scaleX(1)}
.modal-body{padding:28px 32px 36px}
.form-panel{display:none}
.form-panel.active{display:block}
.form-group{margin-bottom:16px}
.form-group label{
  display:block;font-family:var(--font-display);
  font-size:10px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;color:var(--gray-mid);
  margin-bottom:8px;
}
.form-group input{
  width:100%;
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(123,47,190,0.25);
  padding:12px 14px;border-radius:var(--r);
  font-family:var(--font-body);font-size:14px;
  color:var(--white);outline:none;
  transition:border-color 0.25s,box-shadow 0.25s;
}
.form-group input:focus{
  border-color:rgba(123,47,190,0.7);
  box-shadow:0 0 0 3px rgba(123,47,190,0.12);
}
.form-group input::placeholder{color:rgba(255,255,255,0.2)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-forgot{text-align:right;margin:-8px 0 18px}
.form-forgot a{font-size:12px;color:var(--lilac)}
.form-submit{
  width:100%;padding:14px;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  color:var(--white);
  font-family:var(--font-display);font-size:13px;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;
  border-radius:var(--r);transition:var(--trans);
  border:1px solid rgba(123,47,190,0.4);
  box-shadow:0 0 20px rgba(123,47,190,0.3);
}
.form-submit:hover{
  transform:translateY(-2px);
  box-shadow:0 0 40px rgba(123,47,190,0.6);
}
.form-note{
  font-size:11.5px;color:var(--gray-mid);
  text-align:center;margin-top:16px;line-height:1.5;
}
.form-note a{color:var(--lilac)}

/* ============================================
   REVEAL ANIMATIONS
   ============================================ */
.reveal{
  opacity:0;transform:translateY(36px);
  transition:opacity 0.75s cubic-bezier(0.4,0,0.2,1),
              transform 0.75s cubic-bezier(0.4,0,0.2,1);
}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-d1{transition-delay:0.1s}
.reveal-d2{transition-delay:0.2s}
.reveal-d3{transition-delay:0.3s}
.reveal-d4{transition-delay:0.4s}
.reveal-left{opacity:0;transform:translateX(-40px);transition:opacity 0.75s cubic-bezier(0.4,0,0.2,1),transform 0.75s cubic-bezier(0.4,0,0.2,1)}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(40px);transition:opacity 0.75s cubic-bezier(0.4,0,0.2,1),transform 0.75s cubic-bezier(0.4,0,0.2,1)}
.reveal-right.visible{opacity:1;transform:translateX(0)}

/* ============================================
   RESPONSIVE — 1200px
   ============================================ */
@media(max-width:1200px){
  .hero-left{padding:80px 30px 80px 40px}
  .nav-links{gap:24px}
}

/* ============================================
   RESPONSIVE — 1024px (tablets landscape)
   ============================================ */
@media(max-width:1024px){
  .features-grid{grid-template-columns:repeat(2,1fr)}
  .courses-grid{grid-template-columns:repeat(2,1fr)}
  .footer-grid{grid-template-columns:1fr 1fr;gap:36px}
  .test-inner{grid-template-columns:1fr;gap:48px}
  .test-inner .test-left{text-align:center}
  .test-inner .test-left .section-label{justify-content:center}
  .test-btns{justify-content:center}
}

/* ============================================
   RESPONSIVE — 900px (tablets portrait)
   ============================================ */
@media(max-width:900px){
  .hero{
    grid-template-columns:1fr;
    min-height:auto;
  }
  .hero-right{display:none}
  .hero-left{
    padding:calc(var(--nav-h) + 48px) 24px 72px;
    text-align:center;
  }
  .hero-eyebrow{
    margin-left:auto;margin-right:auto;
  }
  .hero-h1{font-size:clamp(2.2rem,7vw,3.6rem)}
  .hero-desc{max-width:100%;font-size:15px}
  .hero-btns{justify-content:center}
  .hero-stats{justify-content:center}

  .about-inner,.video-inner{grid-template-columns:1fr;gap:40px}
  .about-img-main-img{height:400px}
  .features-header{grid-template-columns:1fr;gap:20px}

  .blog-grid{
    grid-template-columns:1fr;
    grid-template-rows:auto;
  }
  .blog-card.featured{grid-row:span 1}
  .blog-card:not(.featured) p{display:block}
}

/* ============================================
   RESPONSIVE — 768px
   ============================================ */
@media(max-width:768px){
  :root{--nav-h:66px}
  .nav-links,.btn-nav-solid{display:none}
  .nav-hamburger{display:flex}
  .btn-nav-ghost span{display:none} /* hide text, keep icon */

  .section-title{font-size:clamp(1.6rem,5.5vw,2.4rem)}

  .courses-grid{grid-template-columns:1fr 1fr}
  .footer-grid{grid-template-columns:1fr 1fr;gap:28px}

  .test-card{padding:28px}
  .test-text{font-size:1rem}
}

/* ============================================
   RESPONSIVE — 600px (mobile)
   ============================================ */
@media(max-width:600px){
  .hero-h1{font-size:clamp(2rem,8vw,2.8rem)}
  .hero-btns{flex-direction:column;align-items:center}
  .hero-btns .btn-primary,.hero-btns .btn-ghost{width:100%;justify-content:center}
  .hero-stat-sep{display:none}
  .hero-stats{gap:20px}

  .features-grid{grid-template-columns:1fr}
  .feat-card{padding:28px 20px}

  .courses-grid{grid-template-columns:1fr}
  .about-img-main-img{height:320px}
  .about-deco{display:none}

  .footer-grid{grid-template-columns:1fr;gap:28px}
  .footer-bottom{flex-direction:column;gap:12px;text-align:center}
  .footer-bottom-links{justify-content:center}

  .modal{border-radius:16px}
  .modal-header{padding:24px 20px 20px}
  .modal-body{padding:20px 20px 28px}
  .form-row{grid-template-columns:1fr}

  .cta-btns{flex-direction:column;align-items:center}
  .cta-btns .btn-primary,.cta-btns .btn-ghost{width:100%;max-width:320px;justify-content:center}

  .test-card{padding:24px 20px}
  .test-text{font-size:0.95rem}

  .blog-card.featured .blog-card-img{height:220px}
}

/* ============================================
   RESPONSIVE — 420px (small phones)
   ============================================ */
@media(max-width:420px){
  .hero-h1{font-size:2rem}
  .loader-title{letter-spacing:6px}
  .loader-subtitle{letter-spacing:3px}
  .loader-ring:nth-child(2){display:none}
  .loader-ring:nth-child(3){display:none}
}

/* ============================================
   WHATSAPP FLOAT BUTTON
   ============================================ */
.whatsapp-float {
  position: fixed;
  bottom: 32px;
  right: 32px;
  z-index: 9000;
  width: 60px; height: 60px;
  background: linear-gradient(135deg, #25D366, #128C7E);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 24px rgba(37,211,102,0.5), 0 0 0 0 rgba(37,211,102,0.4);
  animation: waPulse 2.5s ease-in-out infinite;
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  text-decoration: none;
  color: white;
  overflow: hidden;
}
.whatsapp-float svg {
  width: 32px; height: 32px;
  position: relative; z-index: 2;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
}
.whatsapp-float:hover {
  transform: scale(1.12) rotate(-5deg);
  box-shadow: 0 8px 40px rgba(37,211,102,0.7);
}
.whatsapp-ripple {
  position: absolute; inset: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transform: scale(0);
  animation: waRipple 2.5s ease-in-out infinite;
}
@keyframes waPulse {
  0%, 100% { box-shadow: 0 4px 24px rgba(37,211,102,0.5), 0 0 0 0 rgba(37,211,102,0.4); }
  50%       { box-shadow: 0 4px 24px rgba(37,211,102,0.5), 0 0 0 16px rgba(37,211,102,0); }
}
@keyframes waRipple {
  0%   { transform: scale(0); opacity: 0.5; }
  100% { transform: scale(2.5); opacity: 0; }
}
.whatsapp-tooltip {
  position: absolute;
  right: 70px;
  background: rgba(10,3,20,0.92);
  backdrop-filter: blur(12px);
  color: #fff;
  font-family: var(--font-display);
  font-size: 12px; font-weight: 700;
  letter-spacing: 1px;
  padding: 8px 14px;
  border-radius: 8px;
  white-space: nowrap;
  opacity: 0;
  transform: translateX(8px);
  transition: opacity 0.25s, transform 0.25s;
  border: 1px solid rgba(37,211,102,0.3);
  pointer-events: none;
}
.whatsapp-tooltip::after {
  content: '';
  position: absolute; right: -6px; top: 50%;
  transform: translateY(-50%);
  border: 5px solid transparent;
  border-right: none;
  border-left-color: rgba(10,3,20,0.92);
}
.whatsapp-float:hover .whatsapp-tooltip {
  opacity: 1;
  transform: translateX(0);
}
@media (max-width: 600px) {
  .whatsapp-float { bottom: 20px; right: 20px; width: 52px; height: 52px; }
  .whatsapp-float svg { width: 27px; height: 27px; }
}

/* ============================================
   GALERIA ÉPICA — BENTO GRID
   ============================================ */
.gallery-epic {
  padding: 120px 0 80px;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, var(--purple-dark) 0%, rgba(45,11,90,0.3) 50%, var(--purple-dark) 100%);
}
.gallery-bg-glow {
  position: absolute;
  width: 700px; height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(123,47,190,0.18) 0%, transparent 65%);
  pointer-events: none;
  top: -200px; left: -200px;
  filter: blur(40px);
}
.gallery-bg-glow--2 {
  top: auto; left: auto;
  bottom: -200px; right: -200px;
  background: radial-gradient(circle, rgba(199,125,255,0.12) 0%, transparent 65%);
}
.gallery-container {
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 24px;
}
.gallery-header {
  text-align: center;
  margin-bottom: 64px;
}
.gallery-header .section-label { justify-content: center; }
.gallery-header .section-title { margin: 12px 0 16px; }
.gallery-subtitle {
  font-size: 15px;
  color: var(--text-dim);
  max-width: 480px;
  margin: 0 auto;
  line-height: 1.7;
}

/* BENTO GRID */
.bento-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 16px;
  margin-bottom: 48px;
}

/* Card base */
.bento-card {
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  border: 1px solid rgba(123,47,190,0.2);
  background: rgba(255,255,255,0.025);
  transition: transform 0.4s cubic-bezier(0.4,0,0.2,1),
              box-shadow 0.4s cubic-bezier(0.4,0,0.2,1),
              border-color 0.4s;
  cursor: default;
}
.bento-card:hover {
  transform: translateY(-6px) scale(1.01);
  box-shadow: 0 30px 80px rgba(0,0,0,0.5), 0 0 50px rgba(123,47,190,0.25);
  border-color: rgba(123,47,190,0.5);
}

/* Card hero — spans 2 rows left */
.bento-card--hero {
  grid-column: 1;
  grid-row: 1 / 3;
  display: flex;
  flex-direction: column;
}
.bento-card--hero .bento-img-wrap {
  flex: 1;
  min-height: 340px;
}

/* Card tall — top right */
.bento-card--tall {
  grid-column: 2;
  grid-row: 1;
  min-height: 300px;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* Card community */
.bento-card--community {
  grid-column: 3;
  grid-row: 1;
  min-height: 300px;
}

/* Card numbers */
.bento-card--numbers {
  grid-column: 2;
  grid-row: 2;
  padding: 32px 28px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0;
  background: linear-gradient(135deg, rgba(123,47,190,0.15), rgba(74,14,143,0.2));
  position: relative;
  overflow: hidden;
}
.bento-numbers-bg {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(199,125,255,0.08) 0%, transparent 70%);
  pointer-events: none;
}

/* Card quote */
.bento-card--quote {
  grid-column: 3;
  grid-row: 2;
  padding: 36px 28px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(74,14,143,0.2), rgba(45,11,90,0.3));
  position: relative;
  overflow: hidden;
}

/* Bento image */
.bento-img-wrap {
  position: relative;
  overflow: hidden;
  height: 260px;
}
.bento-card--hero .bento-img-wrap { height: 100%; min-height: 300px; }
.bento-card--tall .bento-img-wrap,
.bento-card--community .bento-img-wrap { height: 100%; position: absolute; inset: 0; }

.bento-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.7s cubic-bezier(0.4,0,0.2,1);
}
.bento-card:hover .bento-img-wrap img { transform: scale(1.07); }

.bento-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(26,5,48,0.95) 0%, rgba(26,5,48,0.3) 50%, transparent 100%);
}
.bento-overlay--dark {
  background: linear-gradient(to top, rgba(26,5,48,1) 0%, rgba(26,5,48,0.5) 60%, transparent 100%);
}
.bento-overlay--purple {
  background: linear-gradient(to top, rgba(74,14,143,0.95) 0%, rgba(123,47,190,0.4) 50%, transparent 100%);
}

/* Bento content */
.bento-content {
  padding: 24px;
  position: relative; z-index: 2;
}
.bento-content--overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 28px 24px;
  background: linear-gradient(to top, rgba(26,5,48,0.98), transparent);
}
.bento-content--float {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 28px 24px;
}

.bento-tag {
  display: inline-block;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--lilac);
  background: rgba(123,47,190,0.2);
  border: 1px solid rgba(123,47,190,0.35);
  padding: 4px 10px; border-radius: 50px;
  margin-bottom: 10px;
}
.bento-tag--gold {
  color: #F4D03F;
  background: rgba(244,208,63,0.15);
  border-color: rgba(244,208,63,0.3);
}
.bento-tag--white {
  color: var(--white);
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.2);
}

.bento-content h3 {
  font-family: var(--font-display);
  font-size: 1.2rem; font-weight: 800;
  color: var(--white); line-height: 1.2;
  margin-bottom: 10px;
}
.bento-content h3 em {
  font-style: italic;
  background: linear-gradient(135deg, var(--lilac), var(--white));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.bento-content p {
  font-size: 13px; color: var(--text-dim);
  line-height: 1.6; margin-bottom: 16px;
}

.bento-stats-row {
  display: flex; gap: 20px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,0.07);
}
.bento-stat strong {
  font-family: var(--font-display);
  font-size: 1.4rem; font-weight: 800;
  color: var(--lilac); display: block; line-height: 1;
}
.bento-stat span {
  font-size: 10px; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--gray-mid);
  margin-top: 3px; display: block;
}

.bento-badge {
  position: absolute; top: 16px; left: 16px; z-index: 3;
  background: rgba(26,5,48,0.9);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(123,47,190,0.4);
  border-radius: 50px;
  padding: 7px 14px;
  display: flex; align-items: center; gap: 8px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--lilac);
}
.bento-badge svg { width: 14px; height: 14px; stroke: var(--lilac); flex-shrink: 0; }

.bento-pill {
  position: absolute; top: 16px; right: 16px; z-index: 3;
  background: rgba(26,5,48,0.85);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 50px;
  padding: 6px 12px;
  display: flex; align-items: center; gap: 7px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--white);
}
.bento-live-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: #27ae60;
  animation: blink 1.5s ease-in-out infinite;
  flex-shrink: 0;
}

.bento-btn {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: var(--font-display);
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--lilac);
  border: 1px solid rgba(199,125,255,0.35);
  padding: 8px 16px; border-radius: 50px;
  transition: var(--trans);
  text-decoration: none;
}
.bento-btn:hover {
  background: rgba(199,125,255,0.15);
  border-color: var(--lilac);
  color: var(--white);
}

/* Avatars */
.bento-avatars {
  display: flex; align-items: center;
  margin-top: 16px;
}
.bento-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 2px solid rgba(26,5,48,0.8);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 800;
  color: var(--white);
  margin-left: -8px;
  box-shadow: 0 0 12px rgba(123,47,190,0.4);
  transition: transform 0.2s;
  flex-shrink: 0;
}
.bento-avatar:first-child { margin-left: 0; }
.bento-avatar:hover { transform: translateY(-4px) scale(1.1); z-index: 2; }
.bento-avatar--count {
  background: rgba(26,5,48,0.9);
  border-color: rgba(123,47,190,0.5);
  font-size: 9px;
  color: var(--lilac);
  padding: 0 6px;
  width: auto; border-radius: 20px;
}

/* Numbers card */
.bento-number-item {
  padding: 16px 0;
  position: relative; z-index: 1;
}
.bento-number {
  font-family: var(--font-display);
  font-size: 2.8rem; font-weight: 800;
  background: linear-gradient(135deg, var(--white), var(--lilac));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block; line-height: 1;
}
.bento-number-label {
  font-size: 11px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--gray-mid);
  margin-top: 4px; display: block;
}
.bento-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(123,47,190,0.3), transparent);
}

/* Quote card */
.bento-quote-mark {
  font-family: var(--font-display);
  font-size: 7rem; font-weight: 800;
  color: rgba(123,47,190,0.15);
  line-height: 0.7;
  margin-bottom: 8px;
}
.bento-quote-text {
  font-family: var(--font-body);
  font-size: 1rem; font-style: italic;
  color: rgba(255,255,255,0.85);
  line-height: 1.6;
  flex: 1;
}
.bento-quote-author {
  display: flex; align-items: center; gap: 12px;
  margin-top: 20px;
}
.bento-quote-author strong {
  font-family: var(--font-display);
  font-size: 0.9rem; font-weight: 700;
  color: var(--white); display: block;
}
.bento-quote-author span {
  font-size: 11px; color: var(--gray-mid);
}
.bento-stars {
  color: var(--lilac);
  font-size: 13px; letter-spacing: 2px;
  margin-top: 12px;
}

/* ── FILMSTRIP ── */
.filmstrip-wrap {
  overflow: hidden;
  position: relative;
  padding: 12px 0;
}
.filmstrip-wrap::before,
.filmstrip-wrap::after {
  content: '';
  position: absolute; top: 0; bottom: 0;
  width: 120px; z-index: 2;
  pointer-events: none;
}
.filmstrip-wrap::before {
  left: 0;
  background: linear-gradient(to right, var(--purple-dark), transparent);
}
.filmstrip-wrap::after {
  right: 0;
  background: linear-gradient(to left, var(--purple-dark), transparent);
}
.filmstrip-track {
  display: flex; gap: 12px;
  width: max-content;
  animation: filmscroll 28s linear infinite;
}
.filmstrip-track:hover { animation-play-state: paused; }
@keyframes filmscroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.film-item {
  width: 180px; height: 110px;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(123,47,190,0.2);
  position: relative;
  flex-shrink: 0;
  transition: transform 0.3s, border-color 0.3s;
  cursor: pointer;
}
.film-item:hover {
  transform: scale(1.06);
  border-color: rgba(199,125,255,0.5);
}
.film-item img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.5s;
}
.film-item:hover img { transform: scale(1.1); }
.film-item span {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(26,5,48,0.95), transparent);
  padding: 16px 10px 8px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--gray-light);
}

/* ── BENTO RESPONSIVE ── */
@media (max-width: 1024px) {
  .bento-grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
  }
  .bento-card--hero { grid-column: 1 / 3; grid-row: 1; }
  .bento-card--hero .bento-img-wrap { height: 380px; }
  .bento-card--tall { grid-column: 1; grid-row: 2; min-height: 280px; }
  .bento-card--community { grid-column: 2; grid-row: 2; min-height: 280px; }
  .bento-card--numbers { grid-column: 1; grid-row: 3; }
  .bento-card--quote { grid-column: 2; grid-row: 3; }
}
@media (max-width: 600px) {
  .bento-grid {
    grid-template-columns: 1fr;
  }
  .bento-card--hero { grid-column: 1; grid-row: 1; }
  .bento-card--tall { grid-column: 1; grid-row: 2; min-height: 280px; }
  .bento-card--community { grid-column: 1; grid-row: 3; min-height: 260px; }
  .bento-card--numbers { grid-column: 1; grid-row: 4; }
  .bento-card--quote { grid-column: 1; grid-row: 5; }
  .film-item { width: 140px; height: 88px; }
}
